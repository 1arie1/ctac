{
  "name": "TAC Preview Dark",
  "type": "dark",
  "colors": {},
  "tokenColors": [
    {
      "scope": [
        "keyword.control.htac",
        "keyword.control.sbf"
      ],
      "settings": {
        "foreground": "#4FC1FF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.label.block.htac",
        "entity.name.label.block.sbf"
      ],
      "settings": {
        "foreground": "#7EE787",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "variable.other.register.htac",
        "variable.other.register.sbf"
      ],
      "settings": {
        "foreground": "#79C0FF"
      }
    },
    {
      "scope": [
        "variable.other.memory.htac"
      ],
      "settings": {
        "foreground": "#D2A8FF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "constant.numeric.power.htac"
      ],
      "settings": {
        "foreground": "#FFD166",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "constant.numeric.hex.htac",
        "constant.numeric.decimal.htac",
        "constant.language.boolean.htac",
        "constant.numeric.hex.sbf",
        "constant.numeric.decimal.sbf",
        "constant.language.boolean.sbf"
      ],
      "settings": {
        "foreground": "#F2CC60"
      }
    },
    {
      "scope": [
        "keyword.operator.htac",
        "keyword.operator.sbf"
      ],
      "settings": {
        "foreground": "#C9D1D9"
      }
    },
    {
      "scope": [
        "string.quoted.double.htac",
        "string.quoted.double.sbf"
      ],
      "settings": {
        "foreground": "#FFD1DC"
      }
    },
    {
      "scope": [
        "punctuation.definition.string.begin.htac",
        "punctuation.definition.string.end.htac",
        "punctuation.definition.string.begin.sbf",
        "punctuation.definition.string.end.sbf"
      ],
      "settings": {
        "foreground": "#FF9BB0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "comment.line.number-sign.htac",
        "comment.line.number-sign.sbf",
        "comment.block.sbf"
      ],
      "settings": {
        "foreground": "#8B949E",
        "fontStyle": "italic"
      }
    }
  ]
}
