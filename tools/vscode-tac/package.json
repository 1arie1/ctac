{
  "name": "ctac-vscode",
  "displayName": "CTAC TAC Tools",
  "description": "Syntax highlighting and go-to-definition for human TAC (ctac pp) files.",
  "version": "0.0.1",
  "publisher": "ctac-local",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:htac",
    "onLanguage:sbf"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "htac",
        "aliases": [
          "Human TAC",
          "htac"
        ],
        "extensions": [
          ".htac"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "sbf",
        "aliases": [
          "SBF",
          "sbf"
        ],
        "extensions": [
          ".sbf",
          ".sbf.json"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "htac",
        "scopeName": "source.htac",
        "path": "./syntaxes/htac.tmLanguage.json"
      },
      {
        "language": "sbf",
        "scopeName": "source.sbf",
        "path": "./syntaxes/htac.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "TAC Preview Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/tac-preview-color-theme.json"
      }
    ]
  }
}
