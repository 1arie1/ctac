{
  "name": "ctac-vscode",
  "displayName": "CTAC TAC Tools",
  "description": "Syntax highlighting and go-to-definition for human TAC (ctac pp) files.",
  "version": "0.0.1",
  "publisher": "ctac-local",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/1arie1/ctac.git",
    "directory": "tools/vscode-tac"
  },
  "homepage": "https://github.com/1arie1/ctac/tree/main/tools/vscode-tac",
  "files": [
    "extension.js",
    "language-configuration.json",
    "language-configuration-sbf.json",
    "syntaxes/**/*.json",
    "themes/**/*.json",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:htac",
    "onLanguage:sbf"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "htac",
        "aliases": [
          "Human TAC",
          "htac"
        ],
        "extensions": [
          ".htac"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "sbf",
        "aliases": [
          "SBF",
          "sbf"
        ],
        "extensions": [
          ".sbf"
        ],
        "configuration": "./language-configuration-sbf.json"
      }
    ],
    "grammars": [
      {
        "language": "htac",
        "scopeName": "source.htac",
        "path": "./syntaxes/htac.tmLanguage.json"
      },
      {
        "language": "sbf",
        "scopeName": "source.sbf",
        "path": "./syntaxes/sbf.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "TAC Preview Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/tac-preview-color-theme.json"
      }
    ]
  }
}
